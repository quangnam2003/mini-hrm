# ==========================================
# NextAuth Authentication
# ==========================================

# Generate a secure secret with: openssl rand -base64 32
# This is used to encrypt JWT tokens - NEVER commit this to version control
NEXTAUTH_SECRET=your-secret-key-here

# The URL of your Next.js application
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# ==========================================
# Backend API Configuration
# ==========================================

# Base URL of your backend API (Laravel, Node.js, etc.)
# This should point to your backend server's API endpoint
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ==========================================
# Node Environment
# ==========================================

# Development mode options:
# - development: Enables hot reloading, detailed error messages
# - production: Optimized for production, minified
NODE_ENV=development
